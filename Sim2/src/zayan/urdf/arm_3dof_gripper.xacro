<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="three_dof_arm_gripper">

  <xacro:property name="PI" value="3.141592653589793"/>

  <!-- World link (fixed reference) -->
  <link name="world"/>

  <!-- Fixed joint connecting world to base_link -->
  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ########## Robot Base ########## -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 1: base rotation (yaw) at top of base (Z = 0.025) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <limit lower="${-PI}" upper="${PI}" effort="100" velocity="1.5"/>
  </joint>

  <!-- Link 1: cylinder length 0.15, offset visual/collision to start at joint -->
  <link name="link1">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>    <!-- half length up -->
      <geometry>
        <cylinder radius="0.06" length="0.15"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="${0.6*(3*0.06*0.06 + 0.15*0.15)/12}"
               iyy="${0.6*(3*0.06*0.06 + 0.15*0.15)/12}"
               izz="${0.6*0.06*0.06/2}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 2: shoulder pitch (horizontal Y axis), at top of link1 (Z = 0.15) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>    <!-- top of link1 (0.075 + 0.075) -->
    <limit lower="${-PI/2}" upper="${PI/2}" effort="80" velocity="1.5"/>
  </joint>

  <!-- Link 2: cylinder length 0.25, offset visual/collision -->
  <link name="link2">
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>   <!-- half length up -->
      <geometry>
        <cylinder radius="0.05" length="0.25"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.25"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="${0.8*(3*0.05*0.05 + 0.25*0.25)/12}"
               iyy="${0.8*(3*0.05*0.05 + 0.25*0.25)/12}"
               izz="${0.8*0.05*0.05/2}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 3: wrist pitch (same horizontal Y axis as joint2), at top of link2 (Z = 0.25) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 1 0"/>          <!-- Horizontal Y axis -->
    <origin xyz="0 0 0.25" rpy="0 0 0"/>    <!-- top of link2 -->
    <limit lower="${-PI/2}" upper="${PI/2}" effort="60" velocity="1.5"/>
  </joint>

  <!-- Link 3: cylinder length 0.2, offset visual/collision -->
  <link name="link3">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>     <!-- half length up -->
      <geometry>
        <cylinder radius="0.04" length="0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="${0.5*(3*0.04*0.04 + 0.2*0.2)/12}"
               iyy="${0.5*(3*0.04*0.04 + 0.2*0.2)/12}"
               izz="${0.5*0.04*0.04/2}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Gripper base joint: revolute, same horizontal Y axis as joint2 & joint3 -->
  <joint name="gripper_base_joint" type="revolute">
    <parent link="link3"/>
    <child link="gripper_base"/>
    <axis xyz="0 1 0"/>                     <!-- Horizontal Y axis -->
    <origin xyz="0 0 0.2" rpy="0 0 0"/>     <!-- top of link3 -->
    <limit lower="${-PI/2}" upper="${PI/2}" effort="50" velocity="1.0"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.08 0.08 0.04"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.08 0.08 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ===== ALTERNATIVE SOLUTION: FINGER WITH X-AXIS ROTATION ===== -->
  <!-- Movable finger: rotates about X-axis for scissor-like closing motion -->
  <joint name="gripper_joint" type="revolute">
    <parent link="gripper_base"/>
    <child link="finger"/>
    <axis xyz="1 0 0"/>                     <!-- Rotate about X-axis for parallel closing -->
    <origin xyz="0 0.02 0.02" rpy="0 0 0"/> <!-- Offset in Y -->
    <limit lower="-0.5" upper="0.5" effort="10" velocity="2.0"/>
  </joint>

  <link name="finger">
    <visual>
      <geometry>
        <box size="0.06 0.01 0.08"/>        <!-- Original dimensions kept -->
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.01 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00002" iyy="0.00002" izz="0.00002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Fixed finger: offset in negative Y -->
  <joint name="fixed_finger_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="fixed_finger"/>
    <origin xyz="0 -0.02 0.02" rpy="0 0 0"/> <!-- Offset in negative Y -->
  </joint>

  <link name="fixed_finger">
    <visual>
      <geometry>
        <box size="0.06 0.01 0.08"/>        <!-- Same dimensions as movable finger -->
      </geometry>
      <material name="yellow">
        <color rgba="1 1 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.01 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00002" iyy="0.00002" izz="0.00002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ros2_control configuration -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo integration -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find zayan)/config/arm_3dof_controllers.yaml</parameters>
    </plugin>
  </gazebo>
  
  <!-- Link materials -->
  <gazebo reference="link1">
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="link2">
    <material>Gazebo/Green</material>
  </gazebo>
  <gazebo reference="link3">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="gripper_base">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="finger">
    <material>Gazebo/Yellow</material>
  </gazebo>
  <gazebo reference="fixed_finger">
    <material>Gazebo/Yellow</material>
  </gazebo>
</robot>
